{
  "name": "propnex-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node scripts/bundle-graphql-schema.mjs && tsx watch src/index.ts",
    "build": "node scripts/bundle-graphql-schema.mjs && tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "lint": "eslint src",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- cross-env NODE_ENV=development prisma db push --skip-generate",
    "db:studio": "dotenv -e .env.local -- cross-env NODE_ENV=development prisma studio",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "db:seed:agent-library": "dotenv -e .env.local -- node scripts/seed-agent-library.mjs",
    "seed:demo": "dotenv -e .env.local -- node scripts/seed-demo-company.mjs",
    "db:clean": "dotenv -e .env.local -- node scripts/clean-user-data.mjs",
    "clerk:clean": "dotenv -e .env.local -- node scripts/clean-clerk-data.mjs",
    "db:migrate:local-org-ids": "dotenv -e .env.local -- node scripts/migrate-local-clerk-org-ids.mjs",
    "test": "tsx --test src/server/__tests__/**/*.test.ts src/lib/__tests__/**/*.test.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@clerk/backend": "^2.19.0",
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^173.0.0",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "ioredis": "^5.11.1",
    "mammoth": "^1.12.0",
    "mongodb": "^7.3.0",
    "multer": "^2.0.1",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "randomstring": "^1.3.1",
    "svix": "^1.96.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/randomstring": "^1.3.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
