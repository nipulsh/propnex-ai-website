{
  "name": "propnex-main-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/bundle-graphql-schema.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- cross-env NODE_ENV=development node ../scripts/with-prisma-env.mjs db push --skip-generate",
    "db:studio": "dotenv -e .env.local -- cross-env NODE_ENV=development node ../scripts/with-prisma-env.mjs studio",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "db:seed:agent-library": "dotenv -e .env.local -- node scripts/seed-agent-library.mjs",
    "db:clean": "dotenv -e .env.local -- node scripts/clean-user-data.mjs",
    "clerk:clean": "dotenv -e .env.local -- node scripts/clean-clerk-data.mjs",
    "db:migrate:local-org-ids": "dotenv -e .env.local -- node scripts/migrate-local-clerk-org-ids.mjs",
    "test": "npx tsx --test src/server/__tests__/**/*.test.ts lib/__tests__/**/*.test.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.5.3",
    "@clerk/ui": "^1.17.0",
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/schema": "^10.0.33",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dataloader": "^2.2.3",
    "googleapis": "^173.0.0",
    "graphql": "^16.14.2",
    "graphql-request": "^7.4.0",
    "graphql-yoga": "^5.21.2",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.18.0",
    "mammoth": "^1.12.0",
    "mongodb": "^7.3.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "randomstring": "^1.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.11.0",
    "svix": "^1.96.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/randomstring": "^1.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
